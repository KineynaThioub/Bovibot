# BoviBot — Configuration Environnement
# Copiez ce fichier en .env et remplissez les valeurs

# ── Base de données MySQL ──────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=votre_mot_de_passe
DB_NAME=bovibot

# ── LLM Configuration ─────────────────────────────────────────
# Option 1 : Groq (RECOMMANDÉ — ultra rapide, gratuit, OpenAI-compatible)
# Créer une clé sur https://console.groq.com
OPENAI_API_KEY=gsk_...votre-cle-groq...
LLM_MODEL=llama3-70b-8192
LLM_BASE_URL=https://api.groq.com/openai/v1

# Option 2 : OpenAI
# OPENAI_API_KEY=sk-...votre-cle-openai...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# Option 3 : Ollama local (LLaMA3 / Mistral — hors ligne)
# OPENAI_API_KEY=ollama
# LLM_MODEL=mistral
# LLM_BASE_URL=http://localhost:11434/v1

# ── LLM Fallback (optionnel — Ollama local si primaire indisponible) ──
LLM_FALLBACK_URL=http://localhost:11434/v1
LLM_FALLBACK_KEY=ollama
LLM_FALLBACK_MODEL=mistral

# ── Déploiement ───────────────────────────────────────────────
# Pour Railway/Render : définir ces variables dans le dashboard
PORT=8002
